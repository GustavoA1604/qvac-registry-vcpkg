{
  "name": "tts-cpp",
  "version-date": "2026-04-24",
  "port-version": 1,
  "description": "tts-cpp: text-to-speech inference in pure C/C++ via ggml (currently ships Chatterbox Turbo)",
  "homepage": "https://github.com/GustavoA1604/chatterbox.cpp",
  "license": "MIT",
  "dependencies": [
    {
      "name": "ggml",
      "version>=": "2026-01-30#7"
    },
    {
      "name": "vcpkg-cmake",
      "host": true
    },
    {
      "name": "vcpkg-cmake-config",
      "host": true
    }
  ],
  "default-features": [
    {
      "name": "metal",
      "platform": "osx | ios"
    },
    {
      "name": "vulkan",
      "platform": "windows | linux | android"
    }
  ],
  "features": {
    "metal": {
      "description": "Enable Metal GPU acceleration (macOS/iOS)",
      "dependencies": [
        {
          "name": "ggml",
          "features": [
            "metal"
          ]
        }
      ]
    },
    "vulkan": {
      "description": "Enable Vulkan GPU acceleration",
      "dependencies": [
        {
          "name": "ggml",
          "features": [
            "vulkan"
          ]
        }
      ]
    }
  }
}
