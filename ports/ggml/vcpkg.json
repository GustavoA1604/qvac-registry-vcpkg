{
  "name": "ggml",
  "version-date": "2026-01-30",
  "port-version": 7,
  "description": "Tensor library for machine learning (tetherto fork with overlay patches pre-applied; pinned to upstream ggml 58c38058 + the consolidated speech-stack patch series on the speech branch -- chatterbox metal ops with gated mul_mv+bias fusion, opencl Adreno-whitelist relaxation + persistent kernel cache, ggml-backend DL filename-prefix support).",
  "homepage": "https://github.com/tetherto/qvac-ext-ggml",
  "license": "MIT",
  "dependencies": [
    {
      "name": "vcpkg-cmake",
      "host": true
    },
    {
      "name": "vcpkg-cmake-config",
      "host": true
    }
  ],
  "default-features": [
    {
      "name": "metal",
      "platform": "osx | ios"
    },
    {
      "name": "opencl",
      "platform": "android"
    },
    {
      "name": "vulkan",
      "platform": "windows | linux | android"
    }
  ],
  "features": {
    "cuda": {
      "description": "Enable CUDA GPU backend"
    },
    "metal": {
      "description": "Enable Metal GPU backend (macOS/iOS)"
    },
    "opencl": {
      "description": "Enable OpenCL GPU backend",
      "dependencies": [
        "opencl"
      ]
    },
    "vulkan": {
      "description": "Enable Vulkan GPU backend"
    }
  }
}
