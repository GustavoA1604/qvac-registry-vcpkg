{
  "name": "parakeet-cpp",
  "version-date": "2026-04-28",
  "port-version": 0,
  "description": "Parakeet (NVIDIA FastConformer ASR + Sortformer diarization) inference in pure C++/ggml. Ships CTC, TDT, EOU and Sortformer engines under one Engine umbrella, plus the Phase 13 cross-engine StreamEvent API (VadStateChanged / EndOfTurn).",
  "homepage": "https://github.com/GustavoA1604/qvac-parakeet.cpp",
  "license": "MIT",
  "dependencies": [
    {
      "name": "vcpkg-cmake",
      "host": true
    },
    {
      "name": "vcpkg-cmake-config",
      "host": true
    }
  ],
  "default-features": [
    {
      "name": "metal",
      "platform": "osx | ios"
    }
  ],
  "features": {
    "metal": {
      "description": "Enable Metal GPU acceleration (macOS / iOS)"
    },
    "vulkan": {
      "description": "Enable Vulkan GPU acceleration",
      "dependencies": [
        {
          "name": "vulkan",
          "platform": "!osx & !ios"
        }
      ]
    },
    "cuda": {
      "description": "Enable CUDA GPU acceleration"
    },
    "opencl": {
      "description": "Enable OpenCL GPU acceleration (Android / Adreno)"
    }
  }
}
